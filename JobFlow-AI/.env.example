# ============================================================
# JobFlow-AI — Environment Variables
# ============================================================

# --- AI (Google Gemini Free Tier: 15 RPM, 1500 req/day) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Email OSINT (Hunter.io Free: 25 searches/month) ---
HUNTER_API_KEY=your_hunter_api_key_here

# --- Email Sending (Brevo Free: 300 emails/day) ---
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SMTP_SERVER=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=your_brevo_login
BREVO_SMTP_PASSWORD=your_brevo_smtp_password

# --- Sender Identity ---
SENDER_EMAIL=marvin@yourdomain.com
SENDER_NAME=Marvin BOTTI DANON

# --- Database (Supabase Free: 500MB PostgreSQL) ---
DATABASE_URL=postgresql://user:password@db.xxxx.supabase.co:5432/postgres
# For local dev, use SQLite:
# DATABASE_URL=sqlite:///./jobflow.db

# --- Proxy (Optional — BrightData / SmartProxy) ---
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# --- App Config ---
MAX_DAILY_EMAILS=30
SCRAPE_INTERVAL_MINUTES=15
PREFERRED_LOCATIONS=Paris 1er,Paris 2e,Paris 3e,Paris 4e,Paris 5e,Paris 6e,Paris 7e,Paris 8e,Paris 9e,Paris 16e,Paris 17e,Neuilly-sur-Seine,Boulogne-Billancourt,Levallois-Perret,Issy-les-Moulineaux,La Défense,Saint-Cloud
AVOID_LOCATIONS=Saint-Denis,Aubervilliers,La Courneuve,Pierrefitte,Stains,Bobigny,Bondy,Sevran,Aulnay-sous-Bois,Clichy-sous-Bois,Montfermeil
